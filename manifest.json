{
  "manifest_version": 3,
  "name": "Aevum - Confront time. Live fully.",
  "version": "1.0.2",
  "description": "Transform every new tab into a contemplative visualization of time — a living grid and precision chronometer reflecting the passage of your life.",
  "permissions": [
    "storage"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "aevum@extension",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "favicon-16.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["favicon-16.png", "favicon-32.png"],
      "matches": ["<all_urls>"]
    }
  ]
}